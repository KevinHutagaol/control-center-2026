             <property name="styleSheet">
              <string notr="true">QPushButton {
    background-image: url(:/desain/Motor.png);
    background-repeat: no-repeat;
    background-position: center;

    background-color: transparent;
    border: none;
}

/* Hover: abu muda transparan = efek buram elegan */
QPushButton:hover {
    background-color: rgba(220, 220, 220, 0.35);   /* abu muda */
}

/* Pressed: abu sedikit lebih tebal */
QPushButton:pressed {
    background-color: rgba(200, 200, 200, 0.50);
}
</string>
