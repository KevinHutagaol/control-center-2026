         <property name="styleSheet">
          <string notr="true">/* Background utama stack widget */
QStackedWidget {
    background-color: #FFFFFF;   /* putih bersih */
    border: none;
}

/* Tombol kiri dan kanan dibuat “melebur” dengan background */
QPushButton#btnPrev,
QPushButton#btnNext {
    background-color: transparent;   /* menyatu */
    border: none;
    color: #444444;                  /* warna ikon/text */
    padding: 4px 8px;
}

/* Hover minimalis */
QPushButton#btnPrev:hover,
QPushButton#btnNext:hover {
    background-color: rgba(0,0,0,0.04);   /* bayangan halus */
    border-radius: 4px;
}</string>
